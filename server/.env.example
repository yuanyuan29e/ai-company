# 腾讯混元大模型 API 配置
HUNYUAN_SECRET_ID=your_secret_id_here
HUNYUAN_SECRET_KEY=your_secret_key_here

# 混元 API Key（OpenAI 兼容接口）
HUNYUAN_API_KEY=your_hunyuan_api_key_here

# 混元模型配置
HUNYUAN_CHAT_MODEL=hunyuan-turbos-latest
HUNYUAN_VISION_MODEL=hunyuan-vision

# 视频帧采样间隔（秒）
FRAME_SAMPLE_INTERVAL=3

# 腾讯云 TTS 配置
# 获取方式：https://console.cloud.tencent.com/cam/capi
TTS_SECRET_ID=your_tts_secret_id_here
TTS_SECRET_KEY=your_tts_secret_key_here
TTS_APP_ID=your_app_id_here

# 服务端口（Railway 会自动注入 PORT，本地默认 3001）
PORT=3001

# 允许的前端来源（逗号分隔），生产部署时填 Vercel 域名
# 例：https://ai-company.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
